---
interface Props {
  href: string;
  label: string;
  bg?: "teal" | "black" | "white" | "yellow";
  color?: "teal" | "black" | "white" | "yellow";
}

const { href, label, bg = "teal", color = "white" } = Astro.props;

const bgClass = {
  teal: "bg-weegee-teal",
  black: "bg-weegee-black",
  white: "bg-weegee-white",
  yellow: "bg-weegee-yellow",
}[bg];

const textClass = {
  teal: "text-weegee-teal",
  black: "text-weegee-black",
  white: "text-weegee-white",
  yellow: "text-weegee-yellow",
}[color];

const btnColor = {
  teal: "var(--color-weegee-teal)",
  black: "var(--color-weegee-black)",
  white: "var(--color-weegee-white)",
  yellow: "var(--color-weegee-yellow)",
}[bg];
---

<a
  href={href}
  class={`btn inline-block px-6 py-2 ${bgClass} ${textClass} font-sans rounded-full text-sm font-medium transition-all w-fit`}
  style={`--btn-color: ${btnColor}`}
>
  {label}
</a>

<style>
  .btn {
    outline: 2px solid transparent;
    outline-offset: 3px;
  }
  .btn:hover {
    outline-color: var(--btn-color);
  }
</style>
