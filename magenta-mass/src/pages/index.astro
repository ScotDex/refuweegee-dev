---
import Layout from "../components/Layout.astro";
---

<Layout title="Refuweegee | We're All Fae Somewhere">
  <main class="bg-white min-h-screen pb-24 font-sans">
    <!-- Bento Grid Layout -->
    <section class="max-w-7xl mx-auto px-6 pt-12 pb-6">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 auto-rows-[250px]">
        <!-- Large top story card -->
        <a
          href="/your-words"
          class="md:col-span-2 md:row-span-2 bg-white rounded-3xl overflow-hidden relative group border border-weegee-black/5"
        >
          <img
            src="/assets/letter.webp"
            alt="Glasgow Community"
            class="w-full h-full object-cover transition-transform group-hover:scale-105"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-weegee-black/60 to-transparent"
          >
          </div>
          <div
            class="absolute bottom-8 left-8 right-8 grid grid-cols-[3fr_2fr] items-center gap-4"
          >
            <div class="text-white">
              <h1 class="font-serif text-3xl">Community Stories</h1>
              <p class="text-lg">Read letters fae a local</p>
            </div>
            <div
              class="relative h-12 w-12 rounded-full bg-white/20 overflow-hidden transition-[width] duration-500 ease-in-out group-hover:w-full hidden md:flex items-center self-center justify-self-start"
            >
              <svg
                class="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <polygon points="5,3 19,12 5,21"></polygon>
              </svg>
            </div>
          </div>
        </a>

        <!-- Action teal card -->
        <a
          href="/your-donations"
          class="bg-weegee-teal rounded-3xl p-8 flex flex-col justify-between md:col-span-1 group cursor-pointer no-underline"
        >
          <h2 class="text-2xl font-serif">Welcome Packs</h2>
          <p class="text-lg">Building connections since 2015</p>
          <div
            class="relative mt-4 h-12 w-12 rounded-full bg-white/20 overflow-hidden transition-[width] duration-500 ease-in-out group-hover:w-full hidden md:flex items-center"
          >
            <svg
              class="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <polygon points="5,3 19,12 5,21"></polygon>
            </svg>
          </div>
        </a>

        <!-- Info card -->
        <div
          class="hidden md:block bg-weegee-yellow rounded-3xl p-8 text-black md:col-span-1"
        >
          <p class="text-4xl font-serif mb-2">1,500+</p>
          <p class="text-lg">Packs delivered this month</p>
        </div>

        <!-- Primary image -->
        <div
          class="hidden md:block md:col-span-2 bg-white rounded-3xl overflow-hidden border border-weegee-black/5"
        >
          <img
            src="/assets/group.webp"
            alt="Volunteers"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </section>

    <!-- section 2 -->
    <section class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 auto-rows-[250px]">
        <!-- Small bottom action card -->
        <a
          href="/your-donations"
          class="bg-weegee-teal rounded-3xl p-8 flex flex-col justify-between md:col-span-2 group cursor-pointer no-underline"
        >
          <h3 class="lg:text-5xl uppercase">
            Refuweegee is 10!
          </h3>
          <p>
            Please help us exist for another ten by donating to our anniversary
            fundraiser.
          </p>
          <div
            class="relative h-12 w-12 rounded-full bg-white/20 overflow-hidden transition-[width] duration-500 ease-in-out group-hover:w-full hidden md:flex items-center"
          >
            <svg
              class="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <polygon points="5,3 19,12 5,21"></polygon>
            </svg>
          </div>
        </a>

        <!-- Large bottom action card -->
        <a
          href="/safewithme"
          class="md:col-span-2 md:row-span-2 md:col-start-3 bg-black rounded-3xl overflow-hidden relative group border border-weegee-black/5"
        >
          <img
            src="/assets/safe.webp"
            alt="Glasgow Community"
            class="size-1/2 mx-auto lg:size-3/4 lg:object-cover transition-transform group-hover:scale-105"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-weegee-black/60 to-transparent"
          >
          </div>
          <div
            class="absolute bottom-8 left-8 right-8 lg:grid lg:grid-cols-[3fr_2fr] items-center gap-4"
          >
            <div class="text-white">
              <h3 class="font-serif text-2xl lg:text-3xl">Show your support</h3>
              <p>Get your free poster</p>
            </div>
            <div
              class="relative h-12 w-12 rounded-full bg-white/20 overflow-hidden transition-[width] duration-500 ease-in-out group-hover:w-full hidden md:flex items-center self-center justify-self-start"
            >
              <svg
                class="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <polygon points="5,3 19,12 5,21"></polygon>
              </svg>
            </div>
          </div>
        </a>

        <!-- Secondary Image -->
        <div
          class="hidden md:block md:col-span-2 bg-white rounded-3xl overflow-hidden border border-weegee-black/5"
        >
          <img
            src="/assets/pens.webp"
            alt="Volunteers"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </section>

    <!-- Sticky action bar -->
    <div
      class="fixed bottom-6 left-1/2 -translate-x-1/2 w-3/4 max-w-lg bg-weegee-teal text-white rounded-full py-2 px-8 shadow-2xl flex justify-between items-center z-50 border-2 border-white/20 backdrop-blur-sm"
    >
      <button class="flex flex-col items-center gap-1 group cursor-pointer">
        <img src="/assets/svgs/donate.svg" alt="" class="w-9 h-9 group-hover:-translate-y-1 transition-transform" />
        <span class="text-[10px] uppercase tracking-widest font-bold">Donate</span>
      </button>
      <button class="flex flex-col items-center gap-1 group cursor-pointer">
        <img src="/assets/svgs/volunteer.svg" alt="" class="w-9 h-9 group-hover:-translate-y-1 transition-transform" />
        <span class="text-[10px] uppercase tracking-widest font-bold">Volunteer</span>
      </button>
      <button class="flex flex-col items-center gap-1 group cursor-pointer">
        <img src="/assets/svgs/partners.svg" alt="" class="w-9 h-9 group-hover:-translate-y-1 transition-transform" />
        <span class="text-[10px] uppercase tracking-widest font-bold">Partners</span>
      </button>
    </div>
  </main>
</Layout>
