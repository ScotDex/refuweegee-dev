---
import Layout from "../components/Layout.astro";
import PageBanner from "../components/PageBanner.astro";

// Contentful-ready array structure for the team profiles
const teamMembers = [
  {
    name: "Selina",
    role: "Founder & Director",
    bio: "Always busy, always has time for those who need her.",
    image: "/assets/team/selina.jpg",
    accent: "bg-weegee-teal text-weegee-white"
  },
    {
    name: "Hannah",
    role: "Operations",
    bio: "Ensuring every single welcome box has a fresh pack of Tunnock's teacakes.",
    image: "/assets/team/hannah.jpg",
    accent: "bg-weegee-black text-weegee-white"
  },
  {
    name: "Lily",
    role: "Donations wizard",
    bio: "Sorting, shifting, sifting and organising like a boss.",
    image: "/assets/team/lily.jpg",
    accent: "bg-weegee-yellow text-weegee-black"
  },

  {
    name: "Brogan",
    role: "All things volunteering",
    bio: "The master organizer behind all our wonderful corporate volunteer teams.",
    image: "/assets/team/brogan.jpg",
    accent: "bg-weegee-teal text-weegee-white"
  }
];
---

<Layout title="Meet the Team">
  <PageBanner slot="banner" title="About Us & The Team" background="bg-weegee-teal text-weegee-white" />

  <main class="max-w-7xl mx-auto px-6 py-16">
    
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-20 items-start">
      
      <div class="lg:col-span-7 space-y-6 text-base text-weegee-black/80 leading-relaxed font-sans">
        <p class="text-xl font-light leading-relaxed text-weegee-black/90">
          Refuweegee was set up by Selina Hales in December 2015 to provide a warm welcome to forcibly displaced people arriving in Glasgow.
        </p>
        <p>
          As a result of the amazing response from people in Glasgow and beyond, we have provided over 
          <span class="font-bold text-weegee-teal">10,000</span> community-built, personal welcome packs and emergency support packs to people all over Glasgow and across Scotland.
        </p>
                  <p >
            We try to provide everyone who wishes to get involved with an opportunity to do so; be it through writing a letter, donating essential items, joining us at an event or fundraising.
          </p>
        <p>
          We work with multiple organisations around Scotland, from our partners who distribute welcome packs through to schools and community organisations looking to do something similar in their area. We love hearing from other individuals, organisations, groups and projects and collaborating wherever we can on the very simple objective of making the world a nicer place to live.
        </p>
      </div>

      <div class="lg:col-span-5 space-y-6">
        <div class="bg-weegee-yellow p-8 rounded-3xl border-2 border-weegee-black flex flex-col justify-center">
          <h2 class="text-2xl text-weegee-black font-serif mb-3">Our Aim</h2>
          <p class="text-base text-weegee-black font-sans font-light leading-relaxed">
            To enable the existing community in extending the friendly welcome that Glasgow is world renowned for*. We do this through our welcome packs, our events and our volunteer opportunities.
          </p>
          <p class="text-sm" >* roughguides.com World's friendliest city</p>

        </div>

      </div>

    </section>

    <hr class="border-weegee-black/10 mb-16" />

    <div class="mb-8">
      <h2 class="text-4xl text-weegee-teal tracking-tight font-bold">The team</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {teamMembers.map((member) => (
        <div class="bg-weegee-white border-2 border-weegee-black rounded-3xl overflow-hidden flex flex-col justify-between group transition-all duration-300 hover:shadow-xl">
          
          <!-- Image frame with crisp padding -->
          <div class="p-3 w-full aspect-square">
            <div class="w-full h-full bg-weegee-cream rounded-2xl overflow-hidden border border-weegee-black/5 relative">
              <img 
                src={member.image} 
                alt={`${member.name} - ${member.role}`} 
                class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-500"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Profile Text Block -->
          <div class="px-6 pt-2 flex-1 flex flex-col justify-between">
            <div>
              <h2 class="text-2xl text-weegee-black font-bold tracking-tight mb-1">
                {member.name}
              </h2>
              
              <span class={`inline-block text-xs uppercase tracking-wider font-bold px-3 pt-1.5 pb-2 rounded-full ${member.accent} mb-4`}>
                {member.role}
              </span>
              
              <p class="text-sm text-weegee-black font-sans font-light leading-relaxed">
                {member.bio}
              </p>
            </div>

          </div>

        </div>
      ))}
    </div>
  </main>
</Layout>