---
import Layout from "../components/Layout.astro";
---

<Layout title="Safe with me campaign" pageBackground="bg-weegee-black">
  <!-- Minimalist, high-impact header inside the black layout -->
  <header
    class="max-w-6xl mx-auto px-6 pt-16 pb-8 text-weegee-white border-b border-weegee-white/10"
  >
    <span
      class="text-weegee-teal text-xs uppercase tracking-widest font-bold font-sans"
      >Community Campaign</span
    >
    <h1 class="text-5xl md:text-6xl text-weegee-white mt-2">Safe With Me.</h1>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-12 text-weegee-white">
    <!-- Master Grid Wrapper -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- LEFT CONTAINER: Campaign Pitch & Visual (Spans 7 columns) -->
      <div class="lg:col-span-7 space-y-8">
        <!-- Manifesto Block (Large Text Callout) -->
        <div
          class="bg-weegee-white/5 border border-weegee-white/10 p-8 rounded-3xl backdrop-blur-sm"
        >
          <p
            class="text-xl md:text-2xl font-sans font-light leading-relaxed text-weegee-white/90"
          >
            We're asking businesses, public spaces and individuals to identify
            themselves as a <span class="text-weegee-teal font-medium"
              >safe place</span
            > in these times of rising hate.
          </p>
        </div>

        <!-- Secondary Core Content Split into Readable Paragraphs -->
        <div
          class="space-y-4 text-base text-weegee-white leading-relaxed max-w-2xl pl-2"
        >
          <p>
            By completing your details below you identify your business or
            street (if completing as an individual) as being a safe place. You
            will then show up in our list of safe places and in our soon to
            launch map, where we hope to gather thousands of safe spaces across
            Scotland... and beyond!
          </p>
          <p>
            The idea is that if someone is experiencing hate they can easily
            identify you or your business as a safe place to go. Simple
            community awareness and sharing of the good that we see every day.
          </p>
          <p class="font-serif text-2xl text-weegee-teal pt-2 italic">
            Join us. Be <span
              class="font-bold uppercase tracking-wide not-italic text-weegee-white"
              >Safe With Me.</span
            >
          </p>
        </div>

        <!-- The Interactive Campaign Map Embedded Cleanly -->
        <div
          class="border-2 border-weegee-white/20 rounded-3xl overflow-hidden shadow-2xl"
        >
          <iframe
            src="https://www.google.com/maps/d/embed?mid=1pMKBfI-hZKBY9CRYXfl5g2wH0ileEhM&ehbc=2E312F&ll=55.8617,-4.2583&z=15"
            class="w-full h-100 block filter invert-[0.9] hue-rotate-180"
            title="Safe Spaces Map"></iframe>
          <!-- Note: The quick CSS filter class above flips a standard google map into a beautiful dark mode that matches your page background perfectly! -->
        </div>
      </div>

      <!-- RIGHT CONTAINER: The Campaign Assets & Toolkit (Spans 5 columns) -->
      <!-- Sticks dynamically to the top of the viewport on desktop as you read the left side -->
      <div class="lg:col-span-5 lg:sticky lg:top-8 space-y-6">
        <!-- Poster Download Card (Dark Bento style wrapper) -->
        <div
          class="bg-weegee-white/5 border-2 border-weegee-white/10 p-6 rounded-3xl text-center flex flex-col items-center group"
        >
          <div
            class="w-full aspect-square max-w-60 rounded-2xl overflow-hidden bg-weegee-black p-2 mb-4 border border-weegee-white/10 transition-transform duration-300 group-hover:scale-102"
          >
            <img
              src="/assets/safe.webp"
              alt="Safe With Me campaign poster"
              class="w-full h-full object-contain"
              loading="lazy"
            />
          </div>
          <h3 class="text-lg font-bold text-weegee-white mb-2">
            Display the Poster
          </h3>
          <p class="text-weegee-white mb-4 max-w-sm">
            Download and display this poster in your window, or collect a
            physical print from Refuweegee HQ at 24 George Square.
          </p>
          <a
            href="#"
            class="w-full bg-weegee-white text-weegee-black font-bold py-3 px-4 rounded-xl hover:bg-weegee-teal hover:text-weegee-white transition-colors text-sm"
          >
            Download Window Poster
          </a>
        </div>

        <!-- Badges & Contact Info Card -->
        <div
          class="bg-weegee-teal/10 border-2 border-weegee-teal/30 p-6 rounded-3xl"
        >
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">📍</span>
            <h3 class="text-lg font-bold text-weegee-teal">
              Pin Badges Available
            </h3>
          </div>
          <p class="text-sm text-weegee-white leading-relaxed mb-4">
            Pin badges are available at Refuweegee HQ, and soon in various local
            shops across the city. All profits directly support refugees in
            Glasgow and Scotland.
          </p>
          <p class="text-weegee-white mb-0">Want to stock them?</p>
          <p>
            Get in touch at
            <a
              href="mailto:enquiries@refuweegee.co.uk"
              class="text-weegee-teal underline font-medium"
            >
              enquiries@refuweegee.co.uk
            </a>
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
