---
import Layout from "../components/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Card from "../components/Card.astro";
---

<Layout title="Events">
  <PageBanner slot="banner" title="Events" background="bg-weegee-teal" />

  <div class="pt-12 flex flex-col gap-10">
    <div
      class="bg-weegee-white rounded-3xl border-2 border-weegee-teal p-8 flex flex-col md:flex-row gap-6 items-center overflow-hidden"
    >
      <div class="flex flex-col gap-3 mr-24">
        <h2
          class="text-3xl text-weegee-teal border-b pb-2 border-weegee-teal/10"
        >
          What's on
        </h2>
        <p class="text-base leading-relaxed">
          We run a range of community events — from wellbeing classes to social
          gatherings. Everyone is welcome. For the latest updates follow us on
          social media or get in touch at
          <a
            href="mailto:enquiries@refuweegee.co.uk"
            class="text-weegee-teal underline font-bold"
            >enquiries@refuweegee.co.uk</a
          >.
        </p>
      </div>
      <img
        src="/assets/group.webp"
        alt="Community group"
        class="w-full md:w-80 h-64 object-cover rounded-2xl shrink-0"
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <Card
        title="Pilates with Ote"
        bg="teal"
        image="/assets/pilates.png"
        buttonHref="https://www.refuweegee.co.uk/events"
        buttonLabel="Register"
      >
        <p class="font-semibold mb-1">Wednesday 26 June 2026 &mdash; 15:30</p>
        <p>Refuweegee, 5th floor</p>
        <p class="mt-2">
          Multiple dates available. A great way to move your body and connect
          with the community.
        </p>
      </Card>

      <Card
        title="Beginners Friendly Yoga"
        bg="yellow"
        image="/assets/yoga.png"
        buttonHref="https://www.refuweegee.co.uk/events"
        buttonLabel="Register"
      >
        <p class="font-semibold mb-1">Friday 26 June 2026 &mdash; 10:00</p>
        <p>24 George Square</p>
        <p class="mt-2">
          Multiple dates available. Open to all levels &mdash; no experience
          needed.
        </p>
      </Card>
    </div>
  </div>
</Layout>
