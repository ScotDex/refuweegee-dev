---
import Layout from "../components/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
---

<Layout title="The Refuweegee shop">
  <PageBanner
    slot="banner"
    title="The Refuweegee shop"
    background="bg-weegee-teal"
  />

  <div
    class="max-w-6xl pt-12 grid grid-cols-1 md:grid-cols-8 gap-6 md:gap-8 lg:grid-cols-12"
  >
    <!-- Top Block: Full Width Main Event/Feature (Spans all 3 columns) -->
    <div
      class="bg-weegee-yellow p-8 rounded-3xl flex flex-col md:flex-row gap-6 items-center col-span-full"
    >
      <div class="flex-1">
        <!-- <span
          class="bg-weegee-black text-weegee-white text-xs uppercase tracking-widest px-3 py-1 rounded-full font-bold"
          >Featured Event</span
        > -->
        <h2 class="text-4xl mt-3 mb-2"></h2>
        <p class="text-lg">
          The Refuweegee Shop is a place for you to browse and select items for
          you and your family. You can collect clothing, household items,
          entertainment items, food and toiletries - free of charge.
        </p>
        <p class="text-lg">
          The Refuweegee shop is open to <span class="font-bold">everyone</span> -
          one person per appointment only.
        </p>
      </div>
      <div class="w-full md:w-1/3 aspect-video rounded-2xl overflow-hidden">
        <img
          src="../../public/assets/shop.jpg"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- How to book an appointment -->
    <div
      class="col-span-full bg-weegee-white p-8 rounded-3xl border-2 border-weegee-teal"
    >
      <div class="grid lg:grid-cols-6 gap-8">
        <div
          class="lg:hidden col-span-full bg-weegee-white p-6 rounded-3xl border-2 border-weegee-black"
        >
          <h3 class="text-lg font-bold">
            You <span class="underline">must</span> have an appointment to visit the
            shop
          </h3>
        </div>
        <div class="lg:col-span-4">
          <h2
            class="text-3xl text-weegee-teal border-b pb-2 border-weegee-teal/10 mb-4"
          >
            How to book an appointment
          </h2>
          <p class="text-lg mb-0">
            Appointments must be booked on your behalf by one of our partner
            organisations.
          </p>
          <p class="text-lg">
            This is to ensure that we can give access to the shop to people who
            need it most.
          </p>
          <p class="text-base mb-3">
            Please contact one of the following organisations to arrange an
            appointment on your behalf:
          </p>
          <ul class="list-disc list-inside text-base space-y-1">
            <li>Scottish Refugee Council</li>
            <li>Red Cross</li>
            <li>NHS Health visitors</li>
            <li>Mears</li>
            <li>Migrant Help</li>
            <li>Simon Community</li>
            <li>Govan Community Project</li>
            <li>AMMA</li>
            <li>Central and West Integration Network</li>
          </ul>
          <p class="text-base mt-4">
            Alternatively, your housing officer, ESOL teacher or case worker can
            book an appointment.
          </p>
        </div>
        <div class="lg:col-span-2 flex flex-col gap-4">
          <div
            class="hidden lg:block bg-weegee-white p-6 rounded-3xl border-2 border-weegee-black"
          >
            <h3 class="text-lg font-bold">
              You <span class="underline">must</span> have an appointment to visit
              the shop
            </h3>
          </div>
          <h3 class="text-xl text-weegee-teal">For partners</h3>
          <p class="text-base">
            Partner organisations can book an appointment using the provided
            password. You can request access to this form by emailing
            <a
              href="mailto:enquiries@refuweegee.co.uk"
              class="text-weegee-teal underline font-bold"
              >enquiries@refuweegee.co.uk</a
            >
            or call <a
              href="tel:01414010756"
              class="text-weegee-teal underline font-bold">0141 401 0756</a
            >.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
